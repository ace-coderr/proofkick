# Data source: "mock" (default) or "chain".
# Flip to "chain" once lib/data/chain.ts is implemented against the TxLINE program.
NEXT_PUBLIC_DATA_SOURCE=mock

# Solana RPC + cluster used by the on-chain provider (lib/data/chain.ts).
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
