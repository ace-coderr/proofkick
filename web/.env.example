# Data source: "chain" (live program) or "mock" (default).
# Chain reads the deployed ProofKick program and falls back to mock data when
# the program has no accounts yet, so the core screens stay populated.
NEXT_PUBLIC_DATA_SOURCE=chain

# Deployed ProofKick settlement program (Solana devnet).
NEXT_PUBLIC_PROGRAM_ID=921ys67mT4rn62pg2ZvfkrNoS581bU6u3QJojtBV71Qm

# Solana RPC + cluster used by the on-chain provider (lib/data/chain.ts) and the
# Phantom wallet adapter.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Optional: SPL mint used to display the connected wallet's USDC balance.
# NEXT_PUBLIC_USDC_MINT=

# ── Server-only (TxLINE live ticker) ─────────────────────────────────────────
# /api/ticker reuses the tracer subscribe->activate flow to proxy the live TxLINE
# SSE scores stream. Needs a funded, subscribed devnet keypair. Provide ONE of
# the keypair vars; if absent, the ticker falls back to mock scores.
# TXLINE_KEYPAIR_PATH=~/.config/solana/id.json
# TXLINE_KEYPAIR=[12,34,...]
# TXLINE_API_BASE=https://txline-dev.txodds.com
