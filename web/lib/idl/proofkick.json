  "types": [
    {
      "name": "BinaryOp",
      "docs": [
        "Operator combining two stats before comparison. Mirrors `txoracle::types::BinaryExpression`."
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Add"
          },
          {
            "name": "Subtract"
          }
        ]
