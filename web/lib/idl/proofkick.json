      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "GreaterThan"
          },
          {
            "name": "LessThan"
          },
          {
            "name": "EqualTo"
          }
        ]
      }
    },
    {
      "name": "Market",
